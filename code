root = tk.Tk()
root.title("Ivy League Finder")
root.geometry("600x500")

title_label = tk.Label(root, text="Ivy League Finder", font=("Arial", 24, "bold"))
title_label.pack(pady=20)

info_label = tk.Label(
    root,
    text="Choose a school to see its information.",
    font=("Arial", 14)
)
info_label.pack(pady=10)

result_label = tk.Label(root, text="", font=("Arial", 12), justify="left")
result_label.pack(pady=20)


def show_school_info(school):
    info = ivy_leagues[school]

    result = (
        f"School: {school}\n"
        f"Location: {info['location']}\n"
        f"Founded: {info['founded']}\n"
        f"Strengths: {', '.join(info['strengths'])}\n"
        f"Best For: {info['best_for']}"
    )

    result_label.config(text=result)


for school in ivy_leagues:
    button = tk.Button(
        root,
        text=school,
        width=20,
        command=lambda s=school: show_school_info(s)
    )
    button.pack(pady=5)

root.mainloop()
