        "founded": 1701,
        "strengths": ["Law", "Humanities", "Political Science", "Arts"],
        "best_for": "Humanities and discussion-based learning"
    },

    "Princeton": {
        "location": "Princeton, New Jersey",
        "founded": 1746,
        "strengths": ["Mathematics", "Physics", "Economics", "Public Policy"],
        "best_for": "Research and close faculty interaction"
    },

    "Columbia": {
        "location": "New York City, New York",
        "founded": 1754,
        "strengths": ["Journalism", "International Affairs", "Business"],
        "best_for": "Urban life and networking"
    },

    "UPenn": {
        "location": "Philadelphia, Pennsylvania",
        "founded": 1740,
